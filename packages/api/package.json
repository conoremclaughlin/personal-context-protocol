{
  "name": "@personal-context/api",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "description": "Personal context protocol API server with MCP, Telegram bot, and REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch --exclude 'dist,node_modules,.next,.pcp' src/index.ts",
    "dev:mcp": "tsx watch --exclude 'dist,node_modules,.next,.pcp' src/index.ts",
    "build": "tsc; cp -r src/skills/builtin dist/skills/builtin",
    "start": "node dist/index.js",
    "server": "tsx src/server.ts",
    "server:dev": "tsx watch --exclude 'dist,node_modules,.next,.pcp' src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "yarn test:integration:db && yarn test:integration:runtime",
    "test:integration:db": "yarn workspace @personal-context/shared build && vitest run --config vitest.integration.db.config.ts",
    "test:integration:runtime": "yarn workspace @personal-context/shared build && vitest run --config vitest.integration.runtime.config.ts",
    "test:codex-e2e": "RUN_CODEX_E2E=1 vitest run --config vitest.integration.runtime.config.ts src/services/sessions/codex-runner.integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:connection": "tsx src/test-connection.ts",
    "test:channels": "tsx src/test-channels.ts",
    "benchmark:memory-recall": "tsx src/scripts/benchmark-memory-recall.ts",
    "benchmark:bootstrap-relevance": "tsx src/scripts/benchmark-bootstrap-relevance.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "yarn workspace @personal-context/shared build && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@slack/bolt": "^4.6.0",
    "@supabase/supabase-js": "^2.39.3",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^171.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "link-preview-js": "^3.2.0",
    "node-cron": "^4.2.1",
    "node-diff3": "^3.2.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.15.0",
    "telegramify-markdown": "^1.3.2",
    "winston": "^3.11.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
