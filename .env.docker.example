# Copy to .env.docker and fill values:
#   cp .env.docker.example .env.docker
#
# If your Supabase is running on the host machine (local CLI stack),
# use host.docker.internal instead of localhost.

NODE_ENV=production

INK_PORT_BASE=3001
WEB_PORT=3002
MYRA_HTTP_PORT=3003
API_URL=http://localhost:3001

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
JWT_SECRET=your-jwt-secret-key-min-32-chars-long

LOG_LEVEL=info
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_DISCORD=false
ENABLE_HEARTBEATS=true
ENABLE_REMINDERS=true

MCP_TRANSPORT=http
MCP_REQUIRE_OAUTH=true
MCP_AUTH_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3001
