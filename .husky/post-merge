#!/bin/sh

# Auto-install deps when yarn.lock changes after pull/merge
if git diff --name-only HEAD@{1} HEAD | grep -q "yarn.lock"; then
  echo "⚠️  yarn.lock changed — running yarn install..."
  yarn install
fi

# Nudge direct/production users to refresh build artifacts after pulling new code.
if git diff --name-only HEAD@{1} HEAD | grep -Eq "^(packages/api|packages/web|packages/cli|package.json|yarn.lock)"; then
  echo "ℹ️  Runtime code changed. Run 'yarn prod:refresh' and restart your running server process."
fi
