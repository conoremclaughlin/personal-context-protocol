{
  "name": "personal-context-protocol",
  "version": "1.0.0",
  "private": true,
  "description": "Personal context protocol - MCP server for managing personal context across services",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pm2 start ecosystem.config.cjs",
    "dev:isolated": "PM2_HOME=.pm2 pm2 start ecosystem.config.cjs",
    "dev:direct": "./scripts/dev-direct.sh",
    "dev:mcp": "yarn workspace @personal-context/api dev:mcp",
    "dev:myra:deprecated": "echo 'DEPRECATED: Myra is now triggered via heartbeat reminders through the PCP server. Use yarn dev instead.'",
    "dev:web": "yarn workspace @personal-context/web dev",
    "dev:all": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all",
    "restart:mcp": "pm2 restart mcp",
    "restart:myra:deprecated": "echo 'DEPRECATED: Myra is now triggered via heartbeat reminders. Restart the pcp process instead: pm2 restart pcp'",
    "logs": "pm2 logs",
    "logs:myra:deprecated": "echo 'DEPRECATED: Myra logs are now in the pcp logs.' && pm2 logs pcp",
    "logs:mcp": "pm2 logs mcp",
    "logs:pcp": "tail -n 200 -f $HOME/.pcp/logs/combined.log | jq -r '.timestamp + \" [\" + .level + \"]: \" + .message'",
    "logs:pcp:raw": "tail -n 200 -f $HOME/.pcp/logs/combined.log",
    "logs:pcp:errors": "tail -n 200 -f $HOME/.pcp/logs/error.log | jq -r '.timestamp + \" [\" + .level + \"]: \" + .message'",
    "status": "pm2 status",
    "pm2": "pm2",
    "sb": "yarn workspace @personal-context/cli cli",
    "cli": "yarn workspace @personal-context/cli cli",
    "ws": "yarn workspace @personal-context/cli cli ws",
    "ws:create": "yarn ws create",
    "ws:list": "yarn ws list",
    "ws:status": "yarn ws status",
    "pr:wait-reply": "node scripts/wait-pr-reply.mjs",
    "build": "yarn workspaces run build",
    "build:web": "yarn workspace @personal-context/web build",
    "test": "yarn workspaces run test",
    "lint": "yarn workspaces run lint",
    "type-check": "yarn workspaces run type-check",
    "clean": "yarn workspaces run clean && rm -rf node_modules && pm2 delete all",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/personal-context-protocol.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "personal-context",
    "telegram-bot",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "packageManager": "yarn@4.12.0"
}
