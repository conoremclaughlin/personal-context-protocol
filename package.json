{
  "name": "inkstand",
  "version": "1.0.0",
  "private": true,
  "description": "Inkstand - MCP server for managing personal context across services",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/preflight.mjs && node scripts/dev-concurrently.mjs",
    "dev:api": "yarn workspace @inkstand/api server:dev",
    "dev:web": "yarn workspace @inkstand/web dev",
    "dev:mcp": "yarn workspace @inkstand/api dev:mcp",
    "dev:direct:deprecated": "echo 'DEPRECATED: use yarn dev instead (runs in your shell context).' && ./scripts/dev-direct.sh",
    "prod:direct": "./scripts/prod-direct.sh",
    "prod:refresh": "./scripts/prod-refresh.sh",
    "prod:migrate": "./scripts/prod-migrate.sh",
    "local:status": "node ./scripts/migration-status.mjs --local --workdir .",
    "linked:status": "node ./scripts/migration-status.mjs --linked --workdir .",
    "local:migrate": "./scripts/prod-migrate.sh --local",
    "linked:migrate": "./scripts/prod-migrate.sh --linked",
    "prod:up": "./scripts/prod-up.sh",
    "prod": "yarn prod:up",
    "logs:ink": "tail -n 200 -f $HOME/.ink/logs/combined.log | jq -r '.timestamp + \" [\" + .level + \"]: \" + .message'",
    "logs:pcp:raw": "tail -n 200 -f $HOME/.ink/logs/combined.log",
    "logs:pcp:errors": "tail -n 200 -f $HOME/.ink/logs/error.log | jq -r '.timestamp + \" [\" + .level + \"]: \" + .message'",
    "ink": "yarn workspace @inkstand/cli cli",
    "cli": "yarn workspace @inkstand/cli cli",
    "ws": "yarn workspace @inkstand/cli cli ws",
    "ws:create": "yarn ws create",
    "ws:list": "yarn ws list",
    "ws:status": "yarn ws status",
    "pr:wait-reply": "node scripts/wait-pr-reply.mjs",
    "build": "yarn install && yarn workspace @inkstand/cli build && yarn workspace @inkstand/cli install:cli",
    "build:all": "yarn workspaces foreach -A -t run build",
    "build:web": "yarn workspace @inkstand/web build",
    "test": "yarn workspaces foreach -A -t run test",
    "docker:app:up": "bash ./scripts/docker-app-up.sh",
    "docker:app:down": "bash ./scripts/docker-app-down.sh",
    "docker:app:logs": "docker compose -f ./docker-compose.app.yml logs -f inkstand-app",
    "docker:studio:build": "yarn workspace @inkstand/cli cli studio sandbox build",
    "supabase:local:setup": "bash ./scripts/setup-local-supabase.sh",
    "test:integration:db:local": "bash ./scripts/test-integration-db-local.sh",
    "test:integration:runtime": "yarn workspace @inkstand/api test:integration:runtime",
    "benchmark:memory-recall": "yarn workspace @inkstand/api benchmark:memory-recall",
    "benchmark:bootstrap-relevance": "yarn workspace @inkstand/api benchmark:bootstrap-relevance",
    "backfill:memory-embeddings": "yarn workspace @inkstand/api backfill:memory-embeddings",
    "lint": "yarn workspaces foreach -A run lint",
    "type-check": "yarn workspaces foreach -A -t run type-check",
    "clean": "yarn workspaces foreach -A run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/inkstand.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "inkstand",
    "telegram-bot",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "libsignal": "npm:2.0.1",
    "minimatch@9.0.3": "9.0.7",
    "undici": "6.24.0"
  }
}
